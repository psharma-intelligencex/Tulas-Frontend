# Production build env (loaded automatically by `vite build`).
# Committed on purpose so Vercel bakes the backend URL into the bundle
# WITHOUT needing a dashboard env var. This is a PUBLIC API endpoint
# (visible in the browser network tab), not a secret.
# To point at a different backend, override VITE_SERVER_URL in Vercel
# Project Settings -> Environment Variables (it takes precedence).
VITE_SERVER_URL=https://upescsa.in
