# Frontend environment variables (Vite).
#
# Which file is loaded when:
#   .env.development -> `npm run dev`  (committed; points at the local backend)
#   .env.production  -> `vite build`   (committed; points at the deployed backend)
#   .env             -> both modes, LOWER precedence than the mode files
#                       (gitignored; use only for personal overrides)
#
# On Vercel, a VITE_SERVER_URL project env var (Project -> Settings ->
# Environment Variables) takes precedence over all of these. The value is a
# PUBLIC API endpoint (visible in the browser network tab), not a secret.

VITE_SERVER_URL=https://upescsa.in
